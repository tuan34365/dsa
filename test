}

// Hàm lưu đường đi vào file
void savePathToFile(const vector<string>& path, const string& filename, const UserRequest& req, const string& criterion) {
    ofstream outFile(filename, ios::app);
    if (outFile.is_open()) {
        outFile << "Thoi gian bat dau: " << req.startTime << "\n";
        outFile << "Duong di: ";
        for (size_t i = 0; i < path.size(); ++i) {
            outFile << path[i];
            if (i < path.size() - 1) outFile << " -> ";
        }
        outFile << "\n";

        double totalDistance = 0;
        int totalTime = 0;
        int totalCost = 0;
        for (size_t i = 0; i < path.size() - 1; ++i) {
            for (const Edge& edge : fullGraph[path[i]].adjList) {
                if (edge.destination == path[i + 1]) {
                    totalDistance += edge.distance;
                    totalTime += edge.time;
                    totalCost += edge.cost;
                    break;
                }
            }
        }
        outFile << "Tong khoang cach: " << fixed << setprecision(1) << totalDistance << " km, Thoi gian: " << totalTime
                << " phut, Chi phi: " << totalCost << " VND\n\n";
        outFile.close();
    } else {
        cout << "Khong mo duoc file " << filename << " de ghi!" << endl;
    }
}

// Hàm đọc dữ liệu từ file
void readFromFile(const string& filename) {
    ifstream inFile(filename);
    if (!inFile.is_open()) {
        cout << "Khong mo duoc file " << filename << "!" << endl;
        return;
    }

    string line;
    while (getline(inFile, line)) {
        if (line[0] == '#') continue;
        stringstream ss(line);
        string src, dest, vehicle;
        double distance;
        int time, cost;
        char comma;

        if (getline(ss, src, ',') && getline(ss, dest, ',') &&
            (ss >> distance >> comma >> time >> comma >> cost >> comma) && getline(ss, vehicle)) {
            bool validVehicle = false;
            string mappedVehicle = mapVehicle(vehicle);
            for (const string& v : vehicles) {
                if (v == mappedVehicle) {
                    validVehicle = true;
                    break;
                }
            }
            if (!validVehicle) {
                cout << "Phuong tien khong hop le trong dong: " << line << endl;
                continue;
            }
            addLocation(src);
            addLocation(dest);
            addEdge(src, dest, distance, time, cost, vehicle);
        } else {
            cout << "Loi dinh dang dong: " << line << endl;
        }
    }
    inFile.close();
}

// Hàm nhập tuyến đường từ bàn phím
void inputRoute() {
    string src, dest, vehicle;
    double distance;
    int time, cost;

    cout << "Nhap diem di: ";
    cin.ignore();
    getline(cin, src);
    cout << "Nhap diem den: ";
    getline(cin, dest);
    cout << "Nhap khoang cach (km): ";
    cin >> distance;
    cout << "Nhap thoi gian (phut): ";
    cin >> time;
    cout << "Nhap chi phi (VND): ";
    cin >> cost;
    cout << "Nhap phuong tien: ";
    cin.ignore();
    getline(cin, vehicle);

    // Kiểm tra phương tiện hợp lệ
    bool validVehicle = false;
    string mappedVehicle = mapVehicle(vehicle);
    for (const string& v : vehicles) {
        if (v == mappedVehicle) {
            validVehicle = true;
            break;
        }
    }
    if (!validVehicle) {
        cout << "Phuong tien khong hop le!" << endl;
        return;
    }

    // Kiểm tra dữ liệu đầu vào
    if (distance < 0 || time < 0 || cost < 0) {
        cout << "Du lieu khong hop le (khoang cach, thoi gian, chi phi phai >= 0)!" << endl;
        return;
    }

    addLocation(src);
    addLocation(dest);
    addEdge(src, dest, distance, time, cost, vehicle);

    cout << "Luu vao file? (y/n): ";
    char save;
    cin >> save;
    if (save == 'y' || save == 'Y') {
        ofstream outFile("routes.txt", ios::app);
        if (outFile.is_open()) {
            string normalizedSrc = mapLocation(src);
            string normalizedDest = mapLocation(dest);
            string normalizedVehicle = normalizeString(vehicle);
            outFile << normalizedSrc << "," << normalizedDest << "," << fixed << setprecision(1) << distance << "," << time << "," << cost << "," << normalizedVehicle << "\n";
            outFile.close();
            cout << "Luu thanh cong!" << endl;
        } else {
            cout << "Khong mo duoc file routes.txt de ghi!" << endl;
        }
    }
}

// Hàm nhập yêu cầu người dùng
UserRequest getUserRequest() {
    UserRequest req;
    cout << "Nhap diem bat dau: ";
    cin.ignore();
    getline(cin, req.start);
    cout << "Nhap diem ket thuc: ";
    getline(cin, req.end);
    cout << "Nhap thoi gian bat dau (dinh dang HH:MM): ";
    cin >> req.startTime;
    cout << "Nhap khoang thoi gian mong muon (phut): ";
    cin >> req.duration;
    cout << "Nhap chi phi toi da (VND): ";
    cin >> req.maxCost;
    cout << "Co muon di qua dia diem trung gian khong? (y/n): ";
    char hasMiddle;
    cin >> hasMiddle;
    if (hasMiddle == 'y' || hasMiddle == 'Y') {
        cout << "Nhap dia diem trung gian: ";
        cin.ignore();
        getline(cin, req.middleLocation);
    } else {
        req.middleLocation = "";
    }
    cout << "Nhap phuong tien (bo trong neu khong chon): ";
    cin.ignore();
    getline(cin, req.vehicle);
    cout << "Chon tieu chi (distance/time/cost): ";
    cin >> req.criterion;
    return req;
}

// Hàm menu chính
void menu() {
    // Khởi tạo đồ thị cho các phương tiện
    for (const string& vehicle : vehicles) {
        vehicleGraphs[vehicle] = map<string, Node>();
    }

    while (true) {
        cout << "\n=== Menu Lap Ke Hoach Du Lich ===\n";
        cout << "1. Nhap tuyen duong tu ban phim\n";
        cout << "2. Doc tuyen duong tu file\n";
        cout << "3. Tim duong di bat ky giua 2 dia diem\n";
        cout << "4. Tim duong di ngan nhat (theo khoang cach/thoi gian/chi phi)\n";
        cout << "5. Tim duong di qua dia diem trung gian\n";
        cout << "6. Tim duong di bang mot phuong tien\n";
        cout << "7. Thoat\n";
        cout << "Chon: ";

        int choice;
        if (!(cin >> choice)) {
            cout << "Lua chon khong hop le! Vui long nhap so tu 1 den 7." << endl;
            cin.clear();
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            continue;
        }

        if (choice == 7) break;

        UserRequest req;
        vector<string> path;
        double totalDistance;
        int totalTime, totalCost;

        switch (choice) {
            case 1: {
                inputRoute();
                break;
            }
            case 2: {
                readFromFile("routes.txt");
                break;
            }
            case 3: {
                req = getUserRequest();
                if (!isLocationExist(req.start) || !isLocationExist(req.end)) {
                    cout << "Dia diem khong ton tai!" << endl;
                    break;
                }
                path = bfs(req.start, req.end);
                printPath(path, req, "any");
                if (!path.empty() && checkConstraints(path, req, totalDistance, totalTime, totalCost)) {
                    savePathToFile(path, "path_output.txt", req, "any");
                } else if (!path.empty()) {
                    cout << "Duong di khong thoa man thoi gian hoac chi phi!" << endl;
                }
                break;
            }
            case 4: {
                req = getUserRequest();
                if (req.criterion != "distance" && req.criterion != "time" && req.criterion != "cost") {
                    cout << "Tieu chi khong hop le! Phai la distance, time hoac cost." << endl;
                    break;
                }
                if (!isLocationExist(req.start) || !isLocationExist(req.end)) {
                    cout << "Dia diem khong ton tai!" << endl;
                    break;
                }
                path = dijkstra(req.start, req.end, req.criterion);
                printPath(path, req, req.criterion);
                if (!path.empty() && checkConstraints(path, req, totalDistance, totalTime, totalCost)) {
                    savePathToFile(path, "shortest_path_output.txt", req, req.criterion);
                } else if (!path.empty()) {
                    cout << "Duong di khong thoa man thoi gian hoac chi phi!" << endl;
                }
                break;
            }
            case 5: {
                req = getUserRequest();
                if (req.criterion != "distance" && req.criterion != "time" && req.criterion != "cost") {
                    cout << "Tieu chi khong hop le! Phai la distance, time hoac cost." << endl;
                    break;
                }
                if (req.middleLocation.empty()) {
                    cout << "Vui long nhap dia diem trung gian!" << endl;
                    break;
                }
                if (!isLocationExist(req.start) || !isLocationExist(req.middleLocation) || !isLocationExist(req.end)) {
                    cout << "Dia diem khong ton tai!" << endl;
                    break;
                }
                path = findPathThrough(req.start, req.middleLocation, req.end, req.criterion);
                printPath(path, req, req.criterion);
                if (!path.empty() && checkConstraints(path, req, totalDistance, totalTime, totalCost)) {
                    savePathToFile(path, "path_through_output.txt", req, req.criterion);
                } else if (!path.empty()) {
                    cout << "Duong di khong thoa man thoi gian hoac chi phi!" << endl;
                }
                break;
            }
            case 6: {
                req = getUserRequest();
                if (req.vehicle.empty()) {
                    cout << "Vui long nhap phuong tien!" << endl;
                    break;
                }
                bool validVehicle = false;
                string mappedVehicle = mapVehicle(req.vehicle);
                for (const string& v : vehicles) {
                    if (v == mappedVehicle) {
                        validVehicle = true;
                        break;
                    }
                }
                if (!validVehicle) {
                    cout << "Phuong tien khong hop le!" << endl;
                    break;
                }
                if (req.criterion != "distance" && req.criterion != "time" && req.criterion != "cost") {
                    cout << "Tieu chi khong hop le! Phai la distance, time hoac cost." << endl;
                    break;
                }
                if (!isLocationExist(req.start) || !isLocationExist(req.end)) {
                    cout << "Dia diem khong ton tai!" << endl;
                    break;
                }
                path = dijkstra(req.start, req.end, req.criterion, mappedVehicle);
                printPath(path, req, req.criterion);
                if (!path.empty() && checkConstraints(path, req, totalDistance, totalTime, totalCost)) {
                    savePathToFile(path, "vehicle_path_output.txt", req, req.criterion);
                } else if (!path.empty()) {
                    cout << "Duong di khong thoa man thoi gian hoac chi phi!" << endl;
                }
                break;
            }
            default: {
                cout << "Lua chon khong hop le! Vui long nhap so tu 1 den 7." << endl;
                cin.clear();
                cin.ignore(numeric_limits<streamsize>::max(), '\n');
                break;
            }
        }
    }
}

int main() {
    cout << fixed << setprecision(1);
    menu();
    return 0;
}


