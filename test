        cout << path[i];
        if (i < path.size() - 1) cout << " -> ";
    }
    cout << " |\n";

    for (size_t i = 0; i < path.size() - 1; ++i) {
        for (const Edge& edge : fullGraph[path[i]].adjList) {
            if (edge.destination == path[i + 1]) {
                totalDistance += edge.distance;
                totalTime += edge.time;
                totalCost += edge.cost;
                cout << "| " << setw(10) << path[i] << " -> " << setw(10) << path[i + 1]
                     << " | " << setw(10) << edge.vehicle << " | Khoang cach: " << fixed << setprecision(1) << edge.distance
                     << " km | Thoi gian: " << edge.time << " phut | Chi phi: " << edge.cost << " VND |\n";
                break;
            }
        }
    }
    cout << "+---------------------------------------------+\n";
    cout << "| Tong khoang cach: " << fixed << setprecision(1) << totalDistance << " km, Thoi gian: " << totalTime
