using namespace std;

// Cấu trúc biểu diễn một cạnh
struct Edge {
    string destination;
    double distance;
    int time;
    int cost;
    string vehicle;
};

// Cấu trúc biểu diễn một nút (địa điểm)
struct Node {
    string name;
    vector<Edge> adjList; // Danh sách kề
};

// Cấu trúc lưu yêu cầu người dùng
struct UserRequest {
    string start;
    string end;
    string startTime;
    int duration; // Khoảng thời gian mong muốn (phút)
    int maxCost;  // Chi phí tối đa (VNĐ)
    string middleLocation; // Địa điểm trung gian (nếu có)
    string vehicle; // Phương tiện (nếu có)
    string criterion; // Tiêu chí (distance, time, cost)
};

// Biến toàn cục
map<string, Node> fullGraph; // Đồ thị tổng hợp
map<string, map<string, Node>> vehicleGraphs; // Đồ thị phân loại theo phương tiện
vector<string> vehicles = {"Xe buyt", "Tau hoa", "Oto", "May bay", "Xe may", "Xe dap"};

// Hàm chuẩn hóa chuỗi: in hoa, không khoảng cách
string normalizeString(const string& str) {
    string result = str;
    for (char& c : result) {
        c = toupper(c);
    }
    result.erase(remove(result.begin(), result.end(), ' '), result.end());
    return result;
}

// Hàm chuyển chuỗi thành in thường để so sánh
string toLowerCase(const string& str) {
    string result = str;
    for (char& c : result) {
        c = tolower(c);
    }
    return result;
}

// Hàm ánh xạ địa điểm về dạng chuẩn hóa
string mapLocation(const string& location) {
    return normalizeString(location);
}

// Hàm ánh xạ phương tiện về dạng gốc
string mapVehicle(const string& vehicle) {
    string normalized = normalizeString(vehicle);
    for (const string& v : vehicles) {
        if (normalizeString(v) == normalized) {
            return v;
        }
    }
    return vehicle;
}

// Hàm kiểm tra địa điểm đã tồn tại chưa
bool isLocationExist(const string& location) {
    string normalized = mapLocation(location);
    return fullGraph.find(normalized) != fullGraph.end();
}

// Hàm thêm địa điểm mới vào đồ thị
void addLocation(const string& location) {
    string normalized = mapLocation(location);
    if (fullGraph.find(normalized) == fullGraph.end()) {
        Node newNode;
        newNode.name = normalized;
        fullGraph[normalized] = newNode;
        for (const string& vehicle : vehicles) {
            vehicleGraphs[vehicle][normalized] = newNode;
        }
    }
}

// Hàm thêm cạnh vào đồ thị
void addEdge(const string& src, const string& dest, double distance, int time, int cost, const string& vehicle) {
    string normalizedSrc = mapLocation(src);
    string normalizedDest = mapLocation(dest);
    string mappedVehicle = mapVehicle(vehicle);
    Edge edge = {normalizedDest, distance, time, cost, mappedVehicle};
    fullGraph[normalizedSrc].adjList.push_back(edge);
    if (vehicleGraphs.find(mappedVehicle) != vehicleGraphs.end()) {
        vehicleGraphs[mappedVehicle][normalizedSrc].adjList.push_back(edge);
    }
}

// Hàm BFS tìm đường đi bất kỳ
vector<string> bfs(const string& start, const string& end) {
    string normalizedStart = mapLocation(start);
    string normalizedEnd = mapLocation(end);

    if (fullGraph.find(normalizedStart) == fullGraph.end() || fullGraph.find(normalizedEnd) == fullGraph.end()) {
        return {};
    }

    map<string, string> parent;
    queue<string> q;
    map<string, bool> visited;

    q.push(normalizedStart);
    visited[normalizedStart] = true;

    while (!q.empty()) {
        string current = q.front();
        q.pop();

        if (current == normalizedEnd) {
            vector<string> path;
            string curr = normalizedEnd;
            while (curr != normalizedStart) {
                path.push_back(curr);
                curr = parent[curr];
            }
            path.push_back(normalizedStart);
            reverse(path.begin(), path.end());
            return path;
        }

        for (const Edge& edge : fullGraph[current].adjList) {
            if (!visited[edge.destination]) {
                visited[edge.destination] = true;
                parent[edge.destination] = current;
                q.push(edge.destination);
            }
        }
    }
    return {};
}

// Hàm Dijkstra tìm đường đi ngắn nhất
vector<string> dijkstra(const string& start, const string& end, const string& criterion, const string& vehicle = "all") {
    string normalizedStart = mapLocation(start);
    string normalizedEnd = mapLocation(end);
    string mappedVehicle = mapVehicle(vehicle);

    map<string, Node>& graph = (mappedVehicle == "all") ? fullGraph : vehicleGraphs[mappedVehicle];
    if (graph.find(normalizedStart) == graph.end() || graph.find(normalizedEnd) == graph.end()) {
        return {};
    }

    map<string, double> dist;
    map<string, string> parent;
    priority_queue<pair<double, string>, vector<pair<double, string>>, greater<>> pq;

    for (const auto& node : graph) {
        dist[node.first] = INT_MAX;
    }
    dist[normalizedStart] = 0;
    pq.push({0, normalizedStart});

    while (!pq.empty()) {
        string current = pq.top().second;
        double currentDist = pq.top().first;
        pq.pop();

        if (current == normalizedEnd) {
            vector<string> path;
            string curr = normalizedEnd;
            while (curr != normalizedStart) {
                path.push_back(curr);
                curr = parent[curr];
            }
            path.push_back(normalizedStart);
            reverse(path.begin(), path.end());
            return path;
        }

        for (const Edge& edge : graph[current].adjList) {
            double weight = (criterion == "distance") ? edge.distance :
                           (criterion == "time") ? edge.time : edge.cost;
            if (dist[current] + weight < dist[edge.destination]) {
                dist[edge.destination] = dist[current] + weight;
                parent[edge.destination] = current;
                pq.push({dist[edge.destination], edge.destination});
            }
        }
    }
    return {};
}

// Hàm kiểm tra thời gian và chi phí của đường đi
bool checkConstraints(const vector<string>& path, const UserRequest& req, double& totalDistance, int& totalTime, int& totalCost) {
    totalDistance = 0;
    totalTime = 0;
    totalCost = 0;

    if (path.empty()) return false;

    for (size_t i = 0; i < path.size() - 1; ++i) {
        for (const Edge& edge : fullGraph[path[i]].adjList) {
            if (edge.destination == path[i + 1]) {
                totalDistance += edge.distance;
                totalTime += edge.time;
                totalCost += edge.cost;
                break;
            }
        }
    }

    return totalTime <= req.duration && totalCost <= req.maxCost;
}

// Hàm tìm đường đi qua địa điểm trung gian
vector<string> findPathThrough(const string& start, const string& middle, const string& end, const string& criterion) {
    string normalizedStart = mapLocation(start);
    string normalizedMiddle = mapLocation(middle);
    string normalizedEnd = mapLocation(end);

    vector<string> path1 = dijkstra(normalizedStart, normalizedMiddle, criterion);
    vector<string> path2 = dijkstra(normalizedMiddle, normalizedEnd, criterion);
    if (path1.empty() || path2.empty()) return {};

    path1.pop_back(); // Loại bỏ điểm trung gian để tránh trùng
    path1.insert(path1.end(), path2.begin(), path2.end());
    return path1;
}

